from __future__ import annotations

from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from cyd_engine.render.shapes import Mesh
    from cyd_engine.world.models import WorldData


class TerrainRenderer:
    """Renderizador simple de terreno usando OpenGL inmediato."""
    
    def __init__(self, world: WorldData, mesh: Mesh) -> None:
        self.world = world
        self.mesh = mesh
        self.display_list = None
        self._compile_display_list()
    
    def _compile_display_list(self) -> None:
        """Compilar display list para mejor rendimiento."""
        from pyglet.gl import (
            glGenLists, glNewList, glEndList,
            glBegin, glEnd, glVertex3f, glColor3f, glNormal3f,
            GL_COMPILE, GL_TRIANGLES
        )
        
        self.display_list = glGenLists(1)
        glNewList(self.display_list, GL_COMPILE)
        
        glBegin(GL_TRIANGLES)
        
        for tri_idx in self.mesh.indices:
            # Obtener vértices del triángulo
            v0 = self.mesh.vertices[tri_idx[0]]
            v1 = self.mesh.vertices[tri_idx[1]]
            v2 = self.mesh.vertices[tri_idx[2]]
            
            # Calcular normal (simple, sin normalizar)
            # Para terreno plano esto funciona
            nx, ny, nz = 0.0, 1.0, 0.0
            glNormal3f(nx, ny, nz)
            
            # Color basado en altura
            height = (v0[1] + v1[1] + v2[1]) / 3.0
            color = self._height_to_color(height)
            glColor3f(*color)
            
            # Dibujar vértices
            glVertex3f(*v0)
            glVertex3f(*v1)
            glVertex3f(*v2)
        
        glEnd()
        glEndList()
    
    def _height_to_color(self, height: float) -> tuple[float, float, float]:
        """Convertir altura a color (gradiente de terreno)."""
        if height < 0.2:
            # Agua (azul)
            return (0.2, 0.3, 0.8)
        elif height < 0.4:
            # Playa/Costa (amarillo claro)
            return (0.9, 0.85, 0.6)
        elif height < 0.6:
            # Pradera (verde)
            return (0.3, 0.7, 0.3)
        elif height < 0.75:
            # Bosque (verde oscuro)
            return (0.2, 0.5, 0.2)
        elif height < 0.85:
            # Montaña (gris)
            return (0.5, 0.5, 0.5)
        else:
            # Pico nevado (blanco)
            return (0.95, 0.95, 0.98)
    
    def render(self) -> None:
        """Renderizar el terreno."""
        from pyglet.gl import glCallList
        if self.display_list:
            glCallList(self.display_list)
    
    def cleanup(self) -> None:
        """Liberar recursos."""
        from pyglet.gl import glDeleteLists
        if self.display_list:
            glDeleteLists(self.display_list, 1)